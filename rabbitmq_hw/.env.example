DB_HOST=your-db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
JWT_SECRET=some-strong-secret
JWT_EXPIRES_IN=30m
AWS_REGION=your-aws-region
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET=your-bucket
AWS_ENDPOINT=your-endpoint
CLOUDFRONT_BASE_URL=your-url
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
# Optional: host port mappings when multiple Compose projects run locally (see compose.yaml)
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBIT_QUEUE_ORDERS=orders.process
RABBIT_QUEUE_DLQ=orders.dlq
RABBIT_RETRY_COUNT=3
RABBIT_RETRY_DELAY=1000