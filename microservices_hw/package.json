{
  "name": "microservices-hw",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo: orders-service + payments-service (gRPC)",
  "scripts": {
    "start:orders": "pnpm -C apps/orders-service run start:dev",
    "start:orders:prod": "pnpm -C apps/orders-service run start:prod",
    "build:orders": "pnpm -C apps/orders-service run build",
    "start:payments": "pnpm -C apps/payments-service run start:dev",
    "start:payments:prod": "pnpm -C apps/payments-service run start:prod",
    "build:payments": "pnpm -C apps/payments-service run build",
    "build": "pnpm run build:orders && pnpm run build:payments",
    "install:all": "pnpm install"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0"
}